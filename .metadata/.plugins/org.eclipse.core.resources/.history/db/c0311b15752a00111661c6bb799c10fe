#include "stm32f4xx_syscfg.h"

/**
 * @brief Ánh xạ chân GPIO vào Line ngắt tương ứng
 * Lưu ý: Trong HAL, hàm HAL_GPIO_Init() thực tế đã gọi SYSCFG ngầm định.
 * Hàm này dùng nếu bạn muốn tự tay điều khiển cấu hình hệ thống.
 */
void SYSCFG_Set_EXTI_Line(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin) {
    uint32_t temp = 0x00;
    uint32_t pin_pos = 0;

    // 1. Bật Clock cho SYSCFG
    __HAL_RCC_SYSCFG_CLK_ENABLE();

    // 2. Tìm vị trí pin (0-15)
    for (pin_pos = 0; pin_pos < 16; pin_pos++) {
        if ((GPIO_Pin >> pin_pos) & 0x01) break;
    }

    // 3. Tính toán giá trị dựa trên Port (A=0, B=1, C=2...)
    uint32_t port_index = 0;
    if (GPIOx == GPIOA) port_index = 0;
    else if (GPIOx == GPIOB) port_index = 1;
    else if (GPIOx == GPIOC) port_index = 2;
    else if (GPIOx == GPIOD) port_index = 3;
    else if (GPIOx == GPIOE) port_index = 4;
    else if (GPIOx == GPIOH) port_index = 7;

    // 4. Ghi vào thanh ghi SYSCFG_EXTICR tương ứng (mỗi thanh ghi quản lý 4 line)
    temp = ((uint32_t)0x0F) << (4U * (pin_pos & 0x03U));
    SYSCFG->EXTICR[pin_pos >> 2U] &= ~temp;
    SYSCFG->EXTICR[pin_pos >> 2U] |= (port_index << (4U * (pin_pos & 0x03U)));
}

void SYSCFG_CompensationCell_Control(FunctionalState state) {
    if (state != DISABLE) {
        SYSCFG->CMPCR |= SYSCFG_CMPCR_CMP_PD; // Bật
    } else {
        SYSCFG->CMPCR &= ~SYSCFG_CMPCR_CMP_PD; // Tắt
    }
}
