#ifndef STM32F4XX_EXTI_H
#define STM32F4XX_EXTI_H

#include "stm32f4xx.h"

/* Định nghĩa các kiểu cạnh kích hoạt ngắt */
typedef enum {
    EXTI_EDGE_RISING = 0,
    EXTI_EDGE_FALLING,
    EXTI_EDGE_RISING_FALLING
} EXTI_Edge_t;

/* --- CÁC HÀM TIỆN ÍCH --- */

/**
 * @brief Cấu hình ngắt ngoài cho một chân GPIO
 * @param GPIOx: Cổng (GPIOA, GPIOB,...)
 * @param GPIO_Pin: Chân (GPIO_PIN_0 -> 15)
 * @param Edge: Cạnh kích hoạt (RISING, FALLING, hoặc cả hai)
 */
void EXTI_Config(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin, EXTI_Edge_t Edge);

/**
 * @brief Kích hoạt ngắt trên bộ điều khiển NVIC
 * @param IRQn: Mã ngắt (ví dụ EXTI0_IRQn, EXTI15_10_IRQn)
 * @param Priority: Độ ưu tiên (0 là cao nhất)
 */
void EXTI_Enable_NVIC(IRQn_Type IRQn, uint32_t Priority);

#endif /* STM32F4XX_EXTI_H */
